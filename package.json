{
  "name": "imani-design-system",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "exports": {
    "./variables.css": "./generated/variables.css",
    "./tokens": "./generated/tokens.ts",
    "./tailwind-preset": "./generated/tailwind-preset.js",
    "./rules": "./DESIGN_RULES.md"
  },
  "files": [
    "tokens",
    "generated",
    "DESIGN_RULES.md",
    "public/favicon-real.svg",
    "public/imani-logotype.svg",
    "public/imani-logotype-light.svg"
  ],
  "scripts": {
    "dev": "next dev",
    "prebuild": "bun run tokens:all",
    "build": "next build",
    "assets:brand": "node scripts/generate-brand-assets.mjs",
    "tokens:build": "node style-dictionary.config.js",
    "tokens:all": "bun run tokens:build && bun run assets:brand",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.10.0",
    "recharts": "3.8.0",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
